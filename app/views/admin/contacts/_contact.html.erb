<%= tag.div id: dom_id(contact), class: "glass rounded-2xl border border-white/10 p-4 transition duration-300 hover:border-indigo-500/50" do %>
  <div class="mb-2 flex items-start justify-between">
    <span class="text-xs font-bold uppercase tracking-widest text-indigo-400">
      <%= contact.service_type.presence || "Service non précisé" %>
    </span>
    <div class="h-2 w-2 rounded-full bg-green-500 animate-pulse"></div>
  </div>

  <h4 class="font-bold text-white"><%= contact.full_name %></h4>
  <%= mail_to contact.email, contact.email, class: "mt-1 block truncate text-sm text-gray-500 transition hover:text-indigo-300" %>
  <p class="mt-3 line-clamp-2 text-sm leading-relaxed text-gray-400"><%= contact.message %></p>

  <div class="mt-4 flex items-center justify-between gap-3 border-t border-white/10 pt-4">
    <time class="text-xs text-gray-500" datetime="<%= contact.created_at.iso8601 %>">
      <%= l(contact.created_at, format: :short) %>
    </time>

    <%= form_with model: [:admin, contact], method: :patch, data: { controller: "status" }, class: "shrink-0" do |form| %>
      <%= form.select :status,
                      Contact.status_options_for_select,
                      {},
                      class: "rounded-lg border border-white/10 bg-[#15151a] px-3 py-2 text-xs font-bold text-gray-200 outline-none transition hover:border-indigo-500/60 focus:border-indigo-500",
                      data: { action: "status#submit" } %>
    <% end %>
  </div>
<% end %>
