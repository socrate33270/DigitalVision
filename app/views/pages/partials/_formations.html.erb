<section id="formations" class="px-4 py-24">
  <div class="mx-auto max-w-7xl">
    <div class="glass rounded-lg p-8 md:p-10">
      <div class="mb-10 flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-pink-300">Formations IA</p>
          <h2 class="text-3xl font-extrabold md:text-4xl">Montez vos équipes en compétence</h2>
        </div>
        <%= link_to "Demander le catalogue", "#contact", class: "rounded-lg bg-white px-6 py-3 font-bold text-black transition hover:bg-gray-200" %>
      </div>

      <div class="grid gap-6 lg:grid-cols-3">
        <% formations.each do |formation| %>
          <article class="rounded-lg border border-white/10 bg-white/[0.03] p-6 transition hover:border-pink-400/50">
            <p class="mb-4 inline-flex rounded-full bg-pink-500/10 px-3 py-1 text-sm font-semibold text-pink-200"><%= formation[:duration] %></p>
            <h3 class="mb-3 text-xl font-bold"><%= formation[:title] %></h3>
            <p class="leading-relaxed text-gray-400"><%= formation[:description] %></p>
          </article>
        <% end %>
      </div>
    </div>
  </div>
</section>
