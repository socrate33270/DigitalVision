<section id="contact" class="bg-[#0d0d10] px-4 py-24">
  <div class="mx-auto grid max-w-7xl gap-16 lg:grid-cols-2">
    <div>
      <h2 class="mb-8 text-4xl font-extrabold leading-tight">
        Discutons de votre
        <span class="gradient-text block">prochain projet</span>
      </h2>
      <p class="mb-8 text-lg leading-relaxed text-gray-400">
        Prêt à transformer votre présence en ligne ? Notre équipe d'experts est à votre écoute pour une consultation gratuite de 30 minutes.
      </p>

      <div class="space-y-6">
        <div class="flex items-center gap-4">
          <div class="flex h-10 w-10 items-center justify-center rounded-full bg-gray-800 text-indigo-300">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" /></svg>
          </div>
          <span>Toute la France</span>
        </div>
      </div>
    </div>

    <div id="contact_form" class="glass rounded-lg p-8">
      <% if contact.errors.any? %>
        <div class="mb-6 rounded-lg border border-rose-400/30 bg-rose-500/10 p-4 text-sm text-rose-100">
          <p class="font-semibold">Veuillez corriger les champs suivants :</p>
          <ul class="mt-2 list-disc space-y-1 pl-5">
            <% contact.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with model: contact, url: contacts_path, class: "space-y-6" do |form| %>
        <div class="grid gap-6 sm:grid-cols-2">
          <div>
            <%= form.label :full_name, "Nom complet", class: "mb-2 block text-sm font-medium text-gray-400" %>
            <%= form.text_field :full_name, autocomplete: "name", placeholder: "Jean Dupont", class: "field-control" %>
          </div>
          <div>
            <%= form.label :email, "Email", class: "mb-2 block text-sm font-medium text-gray-400" %>
            <%= form.email_field :email, autocomplete: "email", placeholder: "jean@entreprise.fr", class: "field-control" %>
          </div>
        </div>

        <div>
          <%= form.label :service_type, "Type de service souhaité", class: "mb-2 block text-sm font-medium text-gray-400" %>
          <%= form.select :service_type, Contact::SERVICE_TYPES, { include_blank: "Sélectionner un service" }, class: "field-control bg-[#1a1a1e]" %>
        </div>

        <div>
          <%= form.label :message, "Votre message", class: "mb-2 block text-sm font-medium text-gray-400" %>
          <%= form.text_area :message, rows: 4, placeholder: "Parlez-nous de votre projet...", class: "field-control" %>
        </div>

        <%= form.submit "Envoyer la demande", class: "w-full cursor-pointer rounded-lg bg-indigo-600 py-4 font-bold text-white shadow-xl shadow-indigo-500/20 transition hover:bg-indigo-700" %>
      <% end %>
    </div>
  </div>
</section>
