<section class="relative px-4 pt-32 pb-20 lg:pt-48 lg:pb-32">
  <div class="blob right-[-12%] top-[-18%] animate-pulse"></div>
  <div class="blob bottom-[-10%] left-[-12%] animate-pulse delay-500"></div>

  <div class="mx-auto max-w-7xl text-center">
    <p class="mb-5 text-sm font-semibold uppercase tracking-[0.22em] text-indigo-300">Marketing digital, IA et croissance</p>
    <h1 class="mx-auto mb-6 max-w-5xl text-5xl font-extrabold leading-tight tracking-tight md:text-7xl">
      Propulsez votre marque dans
      <span class="gradient-text block">l'ère de l'IA</span>
    </h1>
    <p class="mx-auto mb-10 max-w-3xl text-lg leading-relaxed text-gray-400 md:text-xl">
      Nous créons des expériences digitales mémorables, automatisons votre croissance et formons vos équipes aux technologies de demain.
    </p>
    <div class="flex flex-col justify-center gap-4 sm:flex-row">
      <%= link_to "Démarrer un projet", "#contact", class: "rounded-lg bg-white px-8 py-4 text-lg font-bold text-black transition hover:bg-gray-200" %>
      <%= link_to "Nos services", "#services", class: "glass rounded-lg px-8 py-4 text-lg font-bold text-white transition hover:bg-white/10" %>
    </div>
  </div>
</section>
