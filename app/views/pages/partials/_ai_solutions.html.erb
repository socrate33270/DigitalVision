<section id="ai" class="relative overflow-hidden px-4 py-24">
  <div class="absolute inset-x-0 top-1/2 h-px bg-gradient-to-r from-transparent via-indigo-500/30 to-transparent"></div>

  <div class="mx-auto grid max-w-7xl items-center gap-12 lg:grid-cols-[1fr_0.9fr]">
    <div>
      <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-pink-300">Solutions IA</p>
      <h2 class="mb-6 text-4xl font-extrabold tracking-tight md:text-5xl">
        Automatisez sans perdre votre
        <span class="gradient-text">exigence de marque</span>
      </h2>
      <p class="mb-8 max-w-2xl text-lg leading-relaxed text-gray-400">
        Nous connectons vos outils, vos données et vos équipes pour créer des systèmes IA fiables, mesurables et adaptés à vos opérations.
      </p>

      <div class="space-y-4">
        <% ai_solutions.each do |solution| %>
          <div class="glass flex items-start gap-4 rounded-lg p-5">
            <span class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-indigo-500/20 text-sm font-bold text-indigo-200">✓</span>
            <p class="text-gray-300"><%= solution %></p>
          </div>
        <% end %>
      </div>
    </div>

    <div class="relative min-h-[420px] overflow-hidden rounded-lg border border-white/10">
      <%= image_tag "https://images.unsplash.com/photo-1677442136019-21780ecad995?auto=format&fit=crop&w=1200&q=80",
                    alt: "Interface numérique alimentée par intelligence artificielle",
                    class: "absolute inset-0 h-full w-full object-cover opacity-70",
                    loading: "lazy" %>
      <div class="absolute inset-0 bg-gradient-to-br from-[#0a0a0c]/20 via-[#0a0a0c]/55 to-[#0a0a0c]"></div>
      <div class="absolute bottom-0 left-0 right-0 p-8">
        <div class="glass rounded-lg p-6">
          <p class="text-sm uppercase tracking-[0.18em] text-indigo-200">Gain opérationnel</p>
          <p class="mt-3 text-4xl font-extrabold">20h+</p>
          <p class="mt-2 text-sm text-gray-300">récupérées chaque semaine sur les tâches répétitives.</p>
        </div>
      </div>
    </div>
  </div>
</section>
